				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
					<Add option="-DRAYLIB_STATIC" />
					<Add directory="include" />
					<Add directory="raylib/include" />
				</Compiler>
				<Linker>
					<Add option="-s" />
